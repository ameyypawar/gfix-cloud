# Postgres connection string (Neon free tier recommended)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gfixcloud

# Anthropic API key — optional; enables RAG-augmented LLM suggestions
ANTHROPIC_API_KEY=

# Generation LLM model identifier
GENERATION_MODEL=claude-haiku-4-5

# Sentence-transformers embedding model (local, keyless, in-process)
EMBED_MODEL=BAAI/bge-small-en-v1.5

# Embedding vector dimension — must match the model above; migration required to change
EMBED_DIM=384

# Path or name of the gfix binary on PATH
GFIX_BIN=gfix

# gfix release version to download in Docker builds
GFIX_VERSION=0.1.0-alpha.6

# Allow gfix to operate on repos outside the current working directory (required for scratch repos in /tmp)
GITFIX_ALLOW_ANY_REPO=1

# Set 1 only when running the optional gfix BYOK baseline in the eval harness
GITFIX_BYOK=0

# HNSW ef_search parameter — controls recall vs latency trade-off at query time
HNSW_EF_SEARCH=40

# Number of similar past resolutions to retrieve for RAG augmentation
RAG_TOP_K=3

# Timeout in seconds for the generation LLM call
LLM_TIMEOUT_SECS=30

# CORS allowed origins for the Next.js frontend
CORS_ORIGINS=http://localhost:3000

# Port the FastAPI server listens on
PORT=8080
